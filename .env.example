# App Analytics 环境变量示例
# 复制为 .env 并按需填值(.env 已被 .gitignore 忽略)
#
# 说明:不同跑法读不同的变量,按你要跑的场景看对应段落。

# ───────────────────────────────────────────────────────
# 数据层 / CLI Skill:查询脚本连数据库用
#   - 本地 Docker 库(docker-compose.yml)默认就是下面这组,通常无需改
# ───────────────────────────────────────────────────────
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=app_analytics
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# ───────────────────────────────────────────────────────
# Web App 后端(backend/):Bedrock + 数据库 + 认证
#   - 本地 run.sh 已设默认值,这里仅说明可覆盖项
# ───────────────────────────────────────────────────────

# Bedrock / 模型(禁裸 model ID 与 us./eu. 前缀,必须 global. 跨区推理)
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1
ANTHROPIC_MODEL=global.anthropic.claude-opus-4-8
# AWS 凭证走标准链(~/.aws / 环境变量 / EC2 实例角色),不在此文件配

# 后端连的 Postgres(本地 run.sh 用 brew 库 5433;云上 compose 注入 db 容器)
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=app_analytics
PGUSER=postgres
PGPASSWORD=

# 服务端口
PORT=8000

# SQL 安全边界(可选,db.py 默认值)
# SQL_MAX_ROWS=1000
# SQL_TIMEOUT_MS=15000

# app 层 Cognito 认证:本地默认关(不设 AUTH_ENABLED 即关闭)
#   云上由 docker-compose.cloud.yml 注入。pool/client id 是公开值,非密钥。
# AUTH_ENABLED=1
# COGNITO_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
